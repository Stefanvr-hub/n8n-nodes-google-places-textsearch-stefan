{
    "name": "n8n-nodes-google-places-textsearch-stefan",
    "version": "0.1.0",
    "description": "n8n community node for Google Places Text Search API",
    "license": "MIT",
    "keywords": [
        "n8n-community-node-package"
    ],
    "author": {
        "name": "Stefanvr-hub",
        "email": "stefan.vranic06@gmail.com"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/Stefanvr-hub/n8n-nodes-google-places-textsearch-stefan.git"
    },
    "scripts": {
        "build": "n8n-node build",
        "build:watch": "tsc --watch",
        "dev": "n8n-node dev",
        "lint": "n8n-node lint",
        "lint:fix": "n8n-node lint --fix",
        "release": "n8n-node release",
        "prepublishOnly": "n8n-node prerelease"
    },
    "files": [
        "dist"
    ],
    "n8n": {
        "n8nNodesApiVersion": 1,
        "credentials": [
            "dist/credentials/GooglePlacesApi.credentials.js"
        ],
        "nodes": [
            "dist/nodes/GooglePlacesTextSearch/GooglePlacesTextSearch.node.js"
        ]
    },
    "devDependencies": {
        "@n8n/node-cli": "*",
        "typescript": "*"
    }
}
